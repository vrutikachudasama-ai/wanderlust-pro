# ─────────────────────────────────────────────
# Wanderlust — Environment Variables Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your_openweathermap_key_here

# MongoDB (uncomment when adding a database)
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/wanderlust?retryWrites=true

# JWT Auth (uncomment when activating backend auth)
# JWT_SECRET=your_very_long_random_secret_here
# JWT_EXPIRES_IN=7d
